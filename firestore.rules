rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- Helpers ----------

    function isSignedIn() {
      return request.auth != null;
    }

    // Auto-share grants are stored at autoShares/{ownerId}_{granteeUid}.
    // Deterministic doc ids let us check access in O(1) via exists().
    function autoShareExists(ownerId) {
      return isSignedIn() && exists(
        /databases/$(database)/documents/autoShares/$(ownerId + '_' + request.auth.uid)
      );
    }

    // Required fields and type checks for recipe writes.
    // Optional fields (source, notes, yield, prepTime, cookTime, totalTime)
    // are intentionally not validated here — let the client own optional shape.
    function isValidRecipe(data) {
      return data.ownerId is string
        && data.title is string
        && data.title.size() > 0
        && data.title.size() <= 500
        && data.ingredients is list
        && data.instructions is list
        && data.category is string
        && data.category.size() > 0
        && data.category.size() <= 100
        && data.tags is list
        && data.sharedWith is list
        // sharedWithDetails is the denormalized {uid, email} mirror used by
        // the share-dialog UI. Optional for backwards-compat with old recipes
        // that predate it — when present must be a list.
        && (!('sharedWithDetails' in data) || data.sharedWithDetails is list)
        && data.searchTokens is list
        && data.createdAt is timestamp
        && data.updatedAt is timestamp;
    }

    // ---------- Recipes ----------

    match /recipes/{recipeId} {
      allow read: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid
        || request.auth.uid in resource.data.sharedWith
        || autoShareExists(resource.data.ownerId)
      );

      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && isValidRecipe(request.resource.data);

      // Update: must remain owned by the same user, no ownership transfer.
      allow update: if isSignedIn()
        && resource.data.ownerId == request.auth.uid
        && request.resource.data.ownerId == resource.data.ownerId
        && isValidRecipe(request.resource.data);

      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;
    }

    // ---------- User preferences (chapters etc.) ----------

    // users/{uid} stores per-user settings — currently the ordered list of
    // chapter names that act as the recipe-book's table of contents.
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
    }

    // ---------- Auto-shares ----------

    // ---------- Favorites ----------

    // favorites/{uid}_{recipeId} — per-user favorites. Deterministic doc id
    // makes toggle / existence checks O(1). The doc id prefix is the
    // authoritative ownership check; the uid field in the body is just a
    // convenience for queries.
    match /favorites/{favoriteId} {
      allow read: if isSignedIn()
        && favoriteId.matches('^' + request.auth.uid + '_.*');

      allow create: if isSignedIn()
        && favoriteId.matches('^' + request.auth.uid + '_.*')
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.recipeId is string
        && request.resource.data.recipeId.size() > 0
        && request.resource.data.createdAt is timestamp;

      allow delete: if isSignedIn()
        && favoriteId.matches('^' + request.auth.uid + '_.*');

      // Favorites are create + delete only — no mutation.
      allow update: if false;
    }

    match /autoShares/{shareId} {
      // Owner can manage their grants; grantee can read grants targeting them
      // (needed for the recipe-list query that fans out across granted owners).
      allow read: if isSignedIn() && (
        resource.data.ownerId == request.auth.uid
        || resource.data.granteeUid == request.auth.uid
      );

      // Create: owner-initiated, doc id must match the deterministic pattern,
      // and you can't grant access to yourself.
      allow create: if isSignedIn()
        && request.resource.data.ownerId == request.auth.uid
        && shareId == request.auth.uid + '_' + request.resource.data.granteeUid
        && request.resource.data.granteeUid is string
        && request.resource.data.granteeUid != request.auth.uid
        && request.resource.data.granteeEmail is string
        && request.resource.data.createdAt is timestamp;

      allow delete: if isSignedIn() && resource.data.ownerId == request.auth.uid;

      // Grants are create + delete only — no mutation.
      allow update: if false;
    }
  }
}
