# ============================================================================
# CLIENT env. Vite inlines anything prefixed VITE_* into the JS bundle at
# build time, so it ends up visible to every browser that loads the app.
# NEVER put server-only secrets here (e.g. ANTHROPIC_API_KEY — that lives as
# a Cloud Functions secret, set via: firebase functions:secrets:set ANTHROPIC_API_KEY)
# ============================================================================

# Firebase web SDK config — Project settings → General → Your apps → Web app.
# The Firebase API key is intentionally public; Firebase Auth uses it as a
# project identifier, not a secret. Per-user access is enforced by
# firestore.rules, not by hiding this key.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional. Project settings → General → Web app → "Measurement ID" (G-...).
# When set, the client lazy-inits Firebase Analytics (GA4) and emits custom
# events via lib/analytics.ts. Leave blank to skip analytics — every
# trackEvent call no-ops silently.
VITE_FIREBASE_MEASUREMENT_ID=

# Set to "1" to point the client at the local Firebase emulator suite.
# Also short-circuits analytics so dev sessions don't pollute prod GA4.
VITE_USE_EMULATOR=

# Base URL of the sibling Grocery app for the "Send to Grocery" deep
# link on a meal plan's grocery list. Defaults to the production host
# (marksgrocerylist.firebaseapp.com — the domain Grocery's Firebase
# Auth authorizes by default). Override for local testing, e.g.
# http://localhost:5173
VITE_GROCERY_APP_URL=
